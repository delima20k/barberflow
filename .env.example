# ======================================================
# .env.example — BarberFlow
# Copie para .env e preencha com seus valores reais.
# NUNCA comite o arquivo .env no repositório.
# ======================================================

# ── Supabase (projeto remoto — dashboard.supabase.com) ──
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Supabase CLI (para scripts de deploy) ──
SUPABASE_ACCESS_TOKEN=sbp_...
SUPABASE_PROJECT_REF=abcdefghijklmnop
SUPABASE_DB_PASSWORD=sua_senha_do_banco

# ── App ──
APP_URL=http://localhost:3000
APP_ENV=development   # development | production

# ── Auth (opcional — para Google/Apple OAuth) ──
# SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
# SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
# SUPABASE_AUTH_EXTERNAL_APPLE_CLIENT_ID=
# SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=
