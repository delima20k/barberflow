{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/cliente/sw.js",
      "headers": [
        { "key": "Service-Worker-Allowed", "value": "/cliente/" },
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/profissional/sw.js",
      "headers": [
        { "key": "Service-Worker-Allowed", "value": "/profissional/" },
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/cliente",           "destination": "/apps/cliente/index.html"     },
    { "source": "/cliente/(.*)",      "destination": "/apps/cliente/$1"              },
    { "source": "/profissional",      "destination": "/apps/profissional/index.html" },
    { "source": "/profissional/(.*)", "destination": "/apps/profissional/$1"         }
  ]
}
