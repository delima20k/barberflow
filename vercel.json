{
  "version": 2,
  "trailingSlash": true,
  "headers": [
    {
      "source": "/cliente/sw.js",
      "headers": [
        { "key": "Service-Worker-Allowed", "value": "/cliente/" },
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/profissional/sw.js",
      "headers": [
        { "key": "Service-Worker-Allowed", "value": "/profissional/" },
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/shared/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/:app(cliente|profissional)/assets/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/cliente/",            "destination": "/apps/cliente/index.html"      },
    { "source": "/cliente/:path*",      "destination": "/apps/cliente/:path*"          },
    { "source": "/profissional/",       "destination": "/apps/profissional/index.html" },
    { "source": "/profissional/:path*", "destination": "/apps/profissional/:path*"     }
  ]
}
